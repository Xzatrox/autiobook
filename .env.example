# LLM provider API keys (set the ones you need)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...

# override default model - MUST include provider prefix
# see https://docs.litellm.ai/docs/providers for full list
# examples:
#   AUTIOBOOK_MODEL=openai/gpt-4o
#   AUTIOBOOK_MODEL=anthropic/claude-3-5-sonnet-20240620
#   AUTIOBOOK_MODEL=gemini/gemini-1.5-pro
#   AUTIOBOOK_MODEL=openai/my-local-model  (for OpenAI-compatible endpoints)
# AUTIOBOOK_MODEL=openai/gpt-4o

# optional: tokens for extended thinking (default: 0 = disabled)
# AUTIOBOOK_THINKING_BUDGET=1024

# optional: custom OpenAI-compatible endpoint (use with openai/ prefix)
# OPENAI_BASE_URL=http://localhost:8080/v1
